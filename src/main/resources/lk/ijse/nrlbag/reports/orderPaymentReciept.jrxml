<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="orderPaymentReciept" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="c4309c0d-1a8d-44f4-802c-6d206127a453">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="MYSQL-NRLBAG"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="ORDER_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[$P{ORDER_ID}]]></defaultValueExpression>
	</parameter>
	<query language="sql"><![CDATA[SELECT
    o.orders_id,
    o.order_date,
    o.deadline,
    o.status AS order_status,
    o.total_cost,

    c.customer_id,
    c.name AS customer_name,
    c.contact AS customer_contact,

    p.payment_id,
    p.payment_date,
    p.type AS payment_type,
    p.amount AS payment_amount,

    IFNULL(SUM(p2.amount), 0) AS total_paid

FROM Orders o

JOIN Customer c
    ON o.customer_id = c.customer_id

LEFT JOIN Payment p
    ON o.orders_id = p.orders_id

LEFT JOIN Payment p2
    ON o.orders_id = p2.orders_id

WHERE o.orders_id = $P{ORDER_ID}

GROUP BY
    o.orders_id,
    o.order_date,
    o.deadline,
    o.status,
    o.total_cost,
    c.customer_id,
    c.name,
    c.contact,
    p.payment_id,
    p.payment_date,
    p.type,
    p.amount
]]></query>
