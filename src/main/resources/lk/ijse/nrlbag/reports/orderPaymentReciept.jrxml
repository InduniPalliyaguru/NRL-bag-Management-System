	<variable name="PAYMENT_STATUS" class="java.lang.String">
		<expression><![CDATA[$V{REMAINING_PAYMENT}.compareTo(new java.math.BigDecimal(0)) == 0 ? "COMPLETED" : "PENDING"]]></expression>
	</variable>
