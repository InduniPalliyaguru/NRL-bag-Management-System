	<parameter name="ORDER_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[$P{ORDER_ID}]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT
    o.orders_id,
    o.order_date,
    o.deadline,
    o.total_cost,

    c.customer_id,
    c.name        AS customer_name,
    c.contact,
    c.address,

    od.product_id,
    pr.name       AS product_name,
    od.quantity,
    od.unit_price

FROM Orders o

JOIN Customer c
    ON o.customer_id = c.customer_id

JOIN Order_Details od
    ON o.orders_id = od.orders_id

JOIN Product pr
    ON od.product_id = pr.product_id

LEFT JOIN Payment p
    ON o.orders_id = p.orders_id

WHERE o.orders_id = $P{ORDER_ID}

GROUP BY
    o.orders_id,
    o.order_date,
    o.deadline,
    o.total_cost,
    c.customer_id,
    c.name,
    c.contact,
    c.address,
    od.product_id,
    pr.name,
    od.quantity,
    od.unit_price
]]></query>
